[dependencies]
go-yq = ">=4.44"          # CRITICAL: NOT "yq" — that installs python-yq v3
shellcheck = ">=0.10"
jq = ">=1.7"
curl = ">=8"
bats-core = ">=1.11"

[feature.lint.dependencies]
shellcheck = ">=0.10"
yamllint = ">=1.35"

[feature.lint.tasks]
